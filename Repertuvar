<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Repertuvarım</title>

<style>

body {
    font-family: Arial, sans-serif;
    background:#111;
    color:white;
    margin:0;
    padding:20px;
}

h1 {
    text-align:center;
}

.song {
    background:#222;
    padding:15px;
    margin:10px 0;
    border-radius:10px;
    cursor:pointer;
    font-size:20px;
}

.lyrics {
    display:none;
    background:#333;
    padding:20px;
    border-radius:10px;
    white-space:pre-line;
    font-size:22px;
    line-height:1.6;
}

button {
    position:fixed;
    right:25px;
    bottom:25px;
    width:60px;
    height:60px;
    border-radius:50%;
    border:none;
    font-size:35px;
    background:#00c853;
    color:white;
}

input, textarea {
    width:100%;
    padding:10px;
    margin:5px 0;
    font-size:18px;
}

.modal {
    display:none;
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background:#000d;
    padding:20px;
}

.box {
    background:#222;
    padding:20px;
    border-radius:15px;
}

</style>

</head>


<body>

<h1>🎸 Repertuvarım</h1>

<div id="songs"></div>


<button onclick="openAdd()">+</button>


<div class="modal" id="modal">

<div class="box">

<h2>Yeni Şarkı</h2>

<input id="title" placeholder="Şarkı adı">

<textarea id="lyrics" rows="10" placeholder="Sözler"></textarea>

<button onclick="addSong()">Kaydet</button>

</div>

</div>



<script>


let songs = JSON.parse(localStorage.getItem("songs")) || [

{
title:"Örnek Şarkı",
lyrics:"Buraya şarkı sözlerini yaz"
}

];


function showSongs(){

let area=document.getElementById("songs");

area.innerHTML="";


songs.forEach((song,index)=>{


let div=document.createElement("div");

div.innerHTML=
`
<div class="song" onclick="openLyrics(${index})">
${song.title}
</div>

<div class="lyrics" id="lyric${index}">
${song.lyrics}
</div>
`;

area.innerHTML+=div.outerHTML;


});

}



function openLyrics(i){

let box=document.getElementById("lyric"+i);

if(box.style.display=="block"){
box.style.display="none";
}

else{
box.style.display="block";
}

}



function openAdd(){

document.getElementById("modal").style.display="block";

}


function addSong(){

let title=document.getElementById("title").value;

let lyrics=document.getElementById("lyrics").value;


songs.push({

title:title,
lyrics:lyrics

});


localStorage.setItem("songs",JSON.stringify(songs));


document.getElementById("modal").style.display="none";


showSongs();


}


showSongs();


</script>


</body>
</html>
